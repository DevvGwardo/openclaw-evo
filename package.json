{
  "name": "openclaw-evo",
  "version": "0.1.0",
  "description": "Self-evolving AI assistant framework for OpenClaw",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:core\" \"npm run dev:dashboard\"",
    "dev:core": "tsx watch src/hub.ts",
    "dev:dashboard": "vite dashboard",
    "build": "tsc -b && vite build dashboard",
    "start": "node dist/hub.js",
    "start:hub": "tsx src/hub.ts",
    "evolve:once": "tsx src/cli.ts --once",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "conf": "^12.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
