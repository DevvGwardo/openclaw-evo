# OpenClaw Evo — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are optional; defaults are shown.

# ── Cycle scheduling ──────────────────────────────────────────────────────────

# How often to run evolution cycles (milliseconds)
# Default: 300000 (5 minutes)
# EVO_CYCLE_INTERVAL_MS=300000

# Minimum failures recorded before generating a skill fix
# Default: 3
# EVO_FAILURE_THRESHOLD=3

# Maximum new skills generated per cycle
# Default: 3
# EVO_MAX_SKILLS_PER_CYCLE=3

# ── Experiment settings ──────────────────────────────────────────────────────

# Number of sessions per experiment arm (control vs treatment)
# Default: 5
# EVO_EXPERIMENT_SESSIONS=5

# Minimum percentage improvement required to promote a skill
# Default: 10
# EVO_MIN_IMPROVEMENT_PCT=10

# Statistical confidence threshold for experiment significance (0–1)
# Default: 0.95
# EVO_STATISTICAL_CONFIDENCE=0.95

# ── OpenClaw integration ─────────────────────────────────────────────────────

# OpenClaw Gateway URL
# Default: http://localhost:18789
# OPENCLAW_GATEWAY_URL=http://localhost:18789

# How often to poll the gateway for events (milliseconds)
# Default: 10000 (10 seconds)
# OPENCLAW_POLL_INTERVAL_MS=10000

# ── Tool builder ─────────────────────────────────────────────────────────────

# Directory where generated skills are written
# Default: ~/.openclaw/skills/
# EVO_SKILL_OUTPUT_DIR=~/.openclaw/skills/

# Directory containing skill templates
# Default: ./templates/
# EVO_SKILL_TEMPLATE_DIR=./templates/

# ── Memory ───────────────────────────────────────────────────────────────────

# Directory for Evo memory/state files
# Default: ~/.openclaw/evo-memory/
# EVO_MEMORY_DIR=~/.openclaw/evo-memory/

# ── Dashboard ────────────────────────────────────────────────────────────────

# Port for the Evo dashboard web UI
# Default: 5174
# EVO_DASHBOARD_PORT=5174
